ummary has been persisted yet (e.g. processing still running\nor never started for this id).","operationId":"get_meeting_summary_api_upload_audio_meeting__request_id__summary_get","security":[{"AuthBearer":[]}],"parameters":[{"name":"request_id","in":"path","required":true,"schema":{"type":"string","title":"Request Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"404":{"description":"Not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/upload_audio/meeting/{request_id}/chunks":{"get":{"tags":["upload_audio"],"summary":"Get Meeting Chunks Api","description":"Return the per-chunk processing results (speaker mappings, action\nitems, key points etc. for each transcript chunk) for a given request_id.\n\nReturns an empty list if processing hasn't produced any chunk rows yet.","operationId":"get_meeting_chunks_api_upload_audio_meeting__request_id__chunks_get","security":[{"AuthBearer":[]}],"parameters":[{"name":"request_id","in":"path","required":true,"schema":{"type":"string","title":"Request Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"404":{"description":"Not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/upload_audio/meeting/{request_id}":{"get":{"tags":["upload_audio"],"summary":"Get Meeting Api","description":"Return both the final summary and the per-chunk results for a meeting.\n\n404 if no summary has been persisted yet.","operationId":"get_meeting_api_upload_audio_meeting__request_id__get","security":[{"AuthBearer":[]}],"parameters":[{"name":"request_id","in":"path","required":true,"schema":{"type":"string","title":"Request Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"404":{"description":"Not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}},"delete":{"tags":["upload_audio"],"summary":"Delete Meeting Api","description":"Delete the final summary and all per-chunk rows for a meeting.\n\nIdempotent: returns 404 only when nothing was found to delete.","operationId":"delete_meeting_api_upload_audio_meeting__request_id__delete","security":[{"AuthBearer":[]}],"parameters":[{"name":"request_id","in":"path","required":true,"schema":{"type":"string","title":"Request Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MeetingDeleteResponse"}}}},"404":{"description":"Not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/gcs-upload/signed-urls":{"post":{"tags":["gcs_upload"],"summary":"Get Signed Urls","description":"Generate signed PUT URLs for each chunk.\nFrontend uploads chunks directly to GCS in parallel using these URLs.","operationId":"get_signed_urls_gcs_upload_signed_urls_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/InitUploadRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"404":{"description":"Not found"},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}},"security":[{"AuthBearer":[]}]}},"/gcs-upload/compose":{"post":{"tags":["gcs_upload"],"summary":"Compose Chunks","description":"After all chunks are uploaded to GCS, this endpoint:\n1. Composes all chunks into a single final file (server-side, no re-upload)\n2. Deletes temporary chunk files\n3. Returns a signed GET URL for the composed file","operationId":"compose_chunks_gcs_upload_compose_post","requestBody":{"co