{
  "manifest_version": 3,
  "name": "MeetMinutes Recorder",
  "version": "1.0.0",
  "description": "Record Google Meet and Microsoft Teams calls and stream them to MeetMinutes.",
  "homepage_url": "https://meetminutes.in",
  "permissions": [
    "tabCapture",
    "activeTab",
    "storage",
    "offscreen",
    "tabs",
    "scripting",
    "alarms",
    "notifications",
    "identity"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*",
    "https://api.meetminutes.in/*",
    "*://127.0.0.1/*",
    "*://localhost/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "MeetMinutes"
  },
  "options_page": "src/options/options.html",
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Start or stop MeetMinutes recording on the active meeting tab"
    },
    "toggle-transcribe": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Start or stop MeetMinutes live transcription on the active meeting tab"
    }
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content/meet.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["src/content/teams.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["src/transcribe/overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/offscreen/offscreen.html",
        "src/permission/mic.html"
      ],
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.meetminutes.in https://*.meetminutes.in wss://api.meetminutes.in wss://*.meetminutes.in ws://127.0.0.1:* ws://localhost:* wss://127.0.0.1:* wss://localhost:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'"
  }
}
